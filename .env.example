# ─── QwenWeaver Self-Host Configuration ───────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# cp .env.example .env

# ─── Required ─────────────────────────────────────────────────────────────────

# Better Auth secret — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-in-production

# Better Auth URL — the base URL of the API server
BETTER_AUTH_URL=http://localhost:3001/api

# Google OAuth credentials (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth credentials (optional)
# GH_CLIENT_ID=
# GH_CLIENT_SECRET=

# ─── Brevo (Email Verification) ───────────────────────────────────────
# Get your API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_EMAIL=koredey4u@gmail.com
BREVO_SENDER_NAME=QwenWeaver

# ─── LLM Provider ────────────────────────────────────────────────────────────

# DashScope API key (Alibaba Cloud) — required for AI agent nodes
DASHSCOPE_API_KEY=

# ─── Database ────────────────────────────────────────────────────────────────

# Path to SQLite file (default) or PostgreSQL connection URI
# SQLite:  DATABASE_URL=./data/qwenweaver.db
# Postgres: DATABASE_URL=postgres://user:pass@host:5432/qwenweaver
DATABASE_URL=./data/qwenweaver.db

# ─── Server ──────────────────────────────────────────────────────────────────

PORT=3001
HOST=0.0.0.0
PUBLIC_URL=http://localhost:3001
LOG_LEVEL=info

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# ─── Encryption ──────────────────────────────────────────────────────────────

# Used to encrypt user credentials at rest — generate with: openssl rand -hex 32
# Falls back to API_SECRET if not set
# CREDENTIALS_ENCRYPTION_KEY=

# ─── Storage ─────────────────────────────────────────────────────────────────

# Storage driver: 'local' (disk) or 'oss' (Alibaba Cloud OSS)
STORAGE_DRIVER=local

# Alibaba Cloud OSS credentials (required when STORAGE_DRIVER=oss)
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=qwenweaver-assets
# OSS_ENDPOINT=

# ─── Redis (optional, for rate limiting) ──────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Agent Limits ──────────────────────────────────────────────────────────

# Max tool-call steps per agent (1-25, default 5)
# MAX_STEPS=5

# ─── Install Mode (set by installer) ─────────────────────────────────────────
# One of: npm, docker, git, image
INSTALL_MODE=npm
QWENWEAVER_ENV_PATH=./.env

# Set during Docker build to track the exact commit
INSTALL_COMMIT_SHA=

# ─── Optional ────────────────────────────────────────────────────────────────

# Set to "true" to disable all telemetry
DISABLE_ANALYTICS=false

# MCP server connection timeout in milliseconds
MCP_TIMEOUT_MS=30000

# Metrics — Bearer token to protect /api/metrics (dev only)
# METRICS_TOKEN=
