# Server
PORT=3001

# JWT Secret — REQUIRED in production (use `openssl rand -hex 32`)
API_SECRET=change-me-in-production

# CORS — comma-separated allowed origins (defaults to localhost:5173,3000,3001 in dev)
# CORS_ORIGINS=https://your-frontend.example.com

# Metrics — optional Bearer token to protect /api/metrics
# METRICS_TOKEN=your-metrics-scraper-token

# Database — SQLite (local dev)
DATABASE_URL=./data/dev.db

# Database — PostgreSQL (cloud), uncomment and comment SQLite line above
# DATABASE_URL=postgres://user:password@host:5432/qwenweaver

# Database — MySQL, uncomment and comment SQLite line above
# DATABASE_URL=mysql://user:password@host:3306/qwenweaver

# Alibaba Cloud DashScope (Qwen models)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Logging
# LOG_LEVEL=info
