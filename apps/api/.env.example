# Server
PORT=3001

# Better Auth secret — REQUIRED in production (use `openssl rand -hex 32`)
BETTER_AUTH_SECRET=change-me-in-production

# Better Auth URL — the base URL of the API server
BETTER_AUTH_URL=http://localhost:3001/api

# Google OAuth credentials (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth credentials (optional)
# GH_CLIENT_ID=
# GH_CLIENT_SECRET=

# CORS — comma-separated allowed origins (defaults to localhost:5173,3000,3001 in dev)
# CORS_ORIGINS=https://your-frontend.example.com

# Metrics — Bearer token to protect /api/metrics
# METRICS_TOKEN=your-metrics-scraper-token

# Database — SQLite (local dev)
DATABASE_URL=./data/dev.db

# Database — PostgreSQL (cloud), uncomment and comment SQLite line above
# DATABASE_URL=postgres://user:password@host:5432/qwenweaver

# Database — MySQL, uncomment and comment SQLite line above
# DATABASE_URL=mysql://user:password@host:3306/qwenweaver

# Alibaba Cloud DashScope (Qwen models)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Logging
# LOG_LEVEL=info

# Encryption key for user credentials — generate with: openssl rand -hex 32
# Falls back to API_SECRET if not set
# CREDENTIALS_ENCRYPTION_KEY=

# Storage driver: 'local' (disk) or 'oss' (Alibaba Cloud OSS)
STORAGE_DRIVER=local

# Alibaba Cloud OSS credentials (required when STORAGE_DRIVER=oss)
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=qwenweaver-assets
# OSS_ENDPOINT=

# Redis (optional, for rate limiting)
# REDIS_URL=redis://localhost:6379

# Max tool-call steps per agent (1-25, default 5)
# MAX_STEPS=5

# Public URL for generating absolute asset URLs
PUBLIC_URL=http://localhost:3001
