{
  "name": "qwenweaver",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "build": "pnpm -r run build",
    "test": "vitest run",
    "typecheck": "pnpm -r run build",
    "lint": "eslint apps/ packages/",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:push": "pnpm --filter @qwenweaver/database drizzle:push",
    "db:generate": "pnpm --filter @qwenweaver/database drizzle:generate"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
